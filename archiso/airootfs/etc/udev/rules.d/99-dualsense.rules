# Sony DualSense (PS5) Controller — USB
SUBSYSTEM=="usb", ATTRS{idVendor}=="054c", ATTRS{idProduct}=="0ce6", MODE="0666"
# Sony DualSense Edge — USB
SUBSYSTEM=="usb", ATTRS{idVendor}=="054c", ATTRS{idProduct}=="0df2", MODE="0666"
# HID access for all users
KERNEL=="hidraw*", ATTRS{idVendor}=="054c", MODE="0666"
# Gamepad evdev access
SUBSYSTEM=="input", ATTRS{name}=="*DualSense*", MODE="0666"
